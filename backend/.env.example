# RIFTLESS backend configuration (phase F4.1)
# Copy to .env and adjust values for local development.
# Do not put secrets or API keys in this file.

# Application environment: development | staging | production
RIFTLESS_APP_ENV=development

# Semantic application version exposed by health/ready endpoints
RIFTLESS_APP_VERSION=0.1.0

# Optional API route prefix (empty string means no prefix)
RIFTLESS_API_PREFIX=

# ASGI bind host and port for local development
RIFTLESS_HOST=127.0.0.1
RIFTLESS_PORT=8000

# Enable FastAPI debug mode (true/false)
RIFTLESS_DEBUG=false
